<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Decorative Orbs -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="-80dp"
        android:layout_marginStart="-80dp"
        android:background="@drawable/bg_orb_blue" />

    <View
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="-60dp"
        android:layout_marginEnd="-60dp"
        android:background="@drawable/bg_orb_cyan" />

    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="center"
        android:layout_marginStart="100dp"
        android:background="@drawable/bg_orb_dark_blue" />

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── Topbar (matches web .topbar) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_topbar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="40dp"
            android:paddingBottom="12dp">

            <!-- Logo -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ChemLab"
                android:textColor="@color/accent_blue"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Nav Links -->
            <HorizontalScrollView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none"
                android:layout_marginStart="12dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/navDashboard"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Dashboard"
                        style="@style/TopbarLinkActive" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/navInventory"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Inventory"
                        style="@style/TopbarLink" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/navRequests"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Requests"
                        style="@style/TopbarLink" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Logout -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Logout"
                android:textSize="13sp"
                style="@style/GlassLogoutButton" />
        </LinearLayout>

        <!-- ── Main Content (scrollable) ── -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Greeting -->
                <!-- Identity Badge -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:gravity="center_vertical">
                    
                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User Name"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvRoleBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:text="STUDENT"
                        android:textColor="@color/accent_blue"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Student Widgets (Default visible for mocking) -->
                <LinearLayout
                    android:id="@+id/layoutStudentWidgets"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="24dp">

                    <!-- Active Flask Widget -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_glass_card"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:layout_marginBottom="16dp">
                        
                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active Flask Workflow"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:drawablePadding="8dp" />
                        
                        <!-- Stepper Mock -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="16dp"
                            android:weightSum="4">
                            
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="✓\nSubmitted"
                                android:textColor="@color/success_green"
                                android:gravity="center"
                                android:textSize="10sp" />
                                
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="⌛\nPending"
                                android:textColor="@color/warning_yellow"
                                android:gravity="center"
                                android:textSize="10sp" />
                                
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="3\nApproved"
                                android:textColor="@color/text_secondary"
                                android:gravity="center"
                                android:textSize="10sp" />
                                
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="4\nReleased"
                                android:textColor="@color/text_secondary"
                                android:gravity="center"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Quick Request Pad -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_glass_card"
                        android:orientation="vertical"
                        android:padding="20dp">
                        
                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quick Request Pad"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />
                            
                        <EditText
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_input"
                            android:hint="Search Chemicals..."
                            android:textColorHint="@color/text_muted"
                            android:textColor="@color/text_primary"
                            android:paddingHorizontal="16dp"
                            android:textSize="14sp" />
                            
                        <com.google.android.material.button.MaterialButton
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="12dp"
                            android:text="Add to Cart"
                            style="@style/GlassButton" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

</FrameLayout>

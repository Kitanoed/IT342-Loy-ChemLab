<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Decorative Orbs -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="-80dp"
        android:layout_marginStart="-80dp"
        android:background="@drawable/bg_orb_blue" />

    <View
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="-60dp"
        android:layout_marginEnd="-60dp"
        android:background="@drawable/bg_orb_cyan" />

    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="center"
        android:layout_marginStart="100dp"
        android:background="@drawable/bg_orb_dark_blue" />

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── Topbar ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_topbar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="40dp"
            android:paddingBottom="12dp">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ChemLab"
                android:textColor="@color/accent_blue"
                android:textSize="18sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none"
                android:layout_marginStart="12dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/navDashboard"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Dashboard"
                        style="@style/TopbarLink" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/navInventory"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Inventory"
                        style="@style/TopbarLink" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/navRequests"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Requests"
                        style="@style/TopbarLink" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/navCurrent"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Item Details"
                        style="@style/TopbarLinkActive" />
                </LinearLayout>
            </HorizontalScrollView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Logout"
                android:textSize="13sp"
                style="@style/GlassLogoutButton" />
        </LinearLayout>

        <!-- ── Page Content ── -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Header Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Inventory Item Details"
                            android:textColor="@color/text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Read-only details, audit logs, and SDS files."
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBack"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Back to Inventory"
                        android:textSize="12sp"
                        style="@style/GlassSecondaryButton" />
                </LinearLayout>

                <!-- Error -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:textColor="@color/error_red"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <!-- Loading -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="32dp"
                    android:indeterminateTint="@color/accent_blue"
                    android:visibility="gone" />

                <!-- Glass Detail Card -->
                <LinearLayout
                    android:id="@+id/detailCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:visibility="gone">

                    <!-- Item Name -->
                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvItemName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Item Name"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <!-- Detail Fields Grid (2 columns) -->
                    <include layout="@layout/detail_field"
                        android:id="@+id/fieldCode" />
                    <include layout="@layout/detail_field"
                        android:id="@+id/fieldName" />
                    <include layout="@layout/detail_field"
                        android:id="@+id/fieldType" />
                    <include layout="@layout/detail_field"
                        android:id="@+id/fieldCategory" />
                    <include layout="@layout/detail_field"
                        android:id="@+id/fieldQuantity" />
                    <include layout="@layout/detail_field"
                        android:id="@+id/fieldStatus" />
                    <include layout="@layout/detail_field"
                        android:id="@+id/fieldLocation" />
                    <include layout="@layout/detail_field"
                        android:id="@+id/fieldLot" />
                    <include layout="@layout/detail_field"
                        android:id="@+id/fieldExpiry" />
                    <include layout="@layout/detail_field"
                        android:id="@+id/fieldLabId" />
                    <include layout="@layout/detail_field"
                        android:id="@+id/fieldVersion" />
                    <include layout="@layout/detail_field"
                        android:id="@+id/fieldUpdated" />

                </LinearLayout>

                <!-- Description Card -->
                <LinearLayout
                    android:id="@+id/descriptionCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:visibility="gone">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Description"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="—"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Safety Notes"
                        android:textColor="@color/error_red"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvSafetyNotes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="—"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

</FrameLayout>

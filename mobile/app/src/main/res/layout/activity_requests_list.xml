<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Decorative Orbs -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="-80dp"
        android:layout_marginStart="-80dp"
        android:background="@drawable/bg_orb_blue" />
    <View
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="-60dp"
        android:layout_marginEnd="-60dp"
        android:background="@drawable/bg_orb_cyan" />
    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="center"
        android:layout_marginStart="100dp"
        android:background="@drawable/bg_orb_dark_blue" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── Topbar ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_topbar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="40dp"
            android:paddingBottom="12dp">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ChemLab"
                android:textColor="@color/accent_blue"
                android:textSize="18sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none"
                android:layout_marginStart="12dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/navDashboard"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Dashboard"
                        style="@style/TopbarLink" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/navInventory"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Inventory"
                        style="@style/TopbarLink" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/navRequests"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Requests"
                        style="@style/TopbarLinkActive" />
                </LinearLayout>
            </HorizontalScrollView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Logout"
                android:textSize="13sp"
                style="@style/GlassLogoutButton" />
        </LinearLayout>

        <!-- ── Page Content ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Requests"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvSubtext"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Submit and track your item requests."
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Filter Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <!-- Status Spinner -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />
                    <android.widget.Spinner
                        android:id="@+id/spinnerStatus"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_glass"
                        android:padding="8dp"
                        android:popupBackground="@color/bg_primary" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnApply"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Apply"
                    android:textSize="13sp"
                    style="@style/GlassButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReset"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:text="Reset"
                    android:textSize="13sp"
                    style="@style/GlassSecondaryButton" />
            </LinearLayout>

            <!-- Error -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:textColor="@color/error_red"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- Loading -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:indeterminateTint="@color/accent_blue"
                android:visibility="gone" />

            <!-- Empty State -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="32dp"
                android:text="No requests found."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- Requests List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRequests"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingTop="4dp"
                android:clipToPadding="false" />

            <!-- Pagination -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end|center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="10dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPrev"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Prev"
                    android:textSize="13sp"
                    android:enabled="false"
                    style="@style/GlassSecondaryButton" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvPageInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:text="Page 1 of 1"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNext"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Next"
                    android:textSize="13sp"
                    android:enabled="false"
                    style="@style/GlassSecondaryButton" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</FrameLayout>
